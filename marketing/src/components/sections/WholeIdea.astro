---
// The About section — third-person, single flowing block, no decoration,
// no images, no pull quote, no signature. Quiet by design.
---

<section
  id="whole-idea"
  class="relative bg-[var(--bg-root)]"
  data-section="whole-idea"
>
  <div class="mx-auto max-w-3xl px-5 sm:px-8 section-tall pb-20 md:pb-28">
    <div class="sticky-title" data-sticky-title>
      <h2>The idea behind this</h2>
    </div>

    <div class="section-body-pin">
      <p
        class="text-[var(--text-primary)] [text-wrap:balance]"
        style="font-family:var(--font-body); font-size:clamp(1.125rem, 2vw, 1.5rem); line-height:1.55; max-width:36em"
      >
        CurlBro is a workout builder and tracker designed to get out of your way.
        <span style="color:var(--text-secondary)"> No account.</span>
        <span style="color:var(--text-secondary)"> No subscription.</span>
        <span style="color:var(--text-secondary)"> No data collection.</span>
        You build it, you run it, you log every set.
        <span style="color:var(--text-secondary)"> Your data stays on your phone.</span>
      </p>
    </div>
  </div>
</section>
