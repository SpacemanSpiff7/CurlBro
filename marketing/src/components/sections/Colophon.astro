---
// Page colophon — single line at the very bottom in display-mono caps.
// Replaces the v3-v4 footer block. App Store reviewer is satisfied by the
// Get in touch section above; this is just the typographic period at the
// end of the page.
---

<div class="border-t border-[var(--border-subtle)]/40">
  <div class="mx-auto max-w-6xl px-5 sm:px-8 py-8">
    <p
      class="font-display text-[11px] font-semibold uppercase tracking-[0.24em] text-[var(--text-tertiary)]"
    >
      Built by
      <a
        href="https://simonelongo.com"
        target="_blank"
        rel="noopener noreferrer"
        class="link-underline text-[var(--text-secondary)]"
      >
        Simone Longo
      </a>
      <span aria-hidden="true"> · </span>
      &copy; 2026
    </p>
  </div>
</div>
